{
  "name": "workers-monorepo-template",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check:deps": "runx check --deps",
    "check:format": "runx check --format",
    "check:lint:all": "run-eslint",
    "test": "vitest",
    "test:ci": "run-vitest-ci",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint:staged": "lefthook run pre-commit",
    "db:generate": "pnpm -F @pnl/types db:generate",
    "db:push": "pnpm -F @pnl/types db:push",
    "db:push:local": "pnpm -F @pnl/types db:push:local",
    "db:push:remote": "pnpm -F @pnl/types db:push:remote",
    "db:seed": "pnpm -F @pnl/types db:seed",
    "db:seed:local": "pnpm -F @pnl/types db:seed:local"
  },
  "devDependencies": {
    "@babel/plugin-transform-explicit-resource-management": "7.28.0",
    "@changesets/cli": "2.29.7",
    "@ianvs/prettier-plugin-sort-imports": "4.6.2",
    "@repo/eslint-config": "workspace:*",
    "@repo/tools": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/workspace-dependencies": "workspace:*",
    "@turbo/gen": "2.5.8",
    "lefthook": "2.1.6",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "prettier": "3.6.2",
    "prettier-plugin-packagejson": "2.5.19",
    "prettier-plugin-toml": "2.0.6",
    "syncpack": "13.0.4",
    "turbo": "2.5.8",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "wrangler": "4.60.0"
  },
  "packageManager": "pnpm@10.14.0"
}
