{
	"name": "pnl-api",
	"version": "0.1.0",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"build:wrangler": "run-wrangler-build",
		"check:lint": "run-eslint",
		"check:types": "run-tsc",
		"check:workers-types": "run-wrangler-types --check",
		"deploy": "run-wrangler-deploy",
		"dev": "run-wrangler-dev",
		"fix:workers-types": "run-wrangler-types",
		"test": "run-vitest"
	},
	"dependencies": {
		"@hono/trpc-server": "0.3.4",
		"@pnl/types": "workspace:*",
		"@repo/hono-helpers": "workspace:*",
		"@trpc/server": "11.1.0",
		"drizzle-orm": "0.44.2",
		"hono": "4.9.11",
		"workers-tagged-logger": "1.0.0",
		"zod": "4.1.12"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.12.6",
		"@cloudflare/workers-types": "4.20260127.0",
		"@repo/eslint-config": "workspace:*",
		"@repo/tools": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "22.15.27",
		"vitest": "3.2.4",
		"wrangler": "4.60.0"
	}
}
