{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "singleQuote": false,
  "endOfLine": "lf",
  "trailingComma": "none",
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    ".changeset",
    ".bun-build",
    ".claude/*.json",
    ".cursor/rules/",
    ".docs/migrations/*.md",
    ".docs/prompts/*.md",
    ".windsurf/rules/",
    "AGENT.md",
    "AGENTS.md",
    "CLAUDE.md",
    "**/dist/**",
    "*.lock",
    "/turbo/generators/**/*.hbs",
    "**/drizzle/meta/**",
    "apps/web/src/routeTree.gen.ts",
    "pnpm-lock.yaml",
    "vite.config.ts.timestamp*",
    "vitest.config.ts.timestamp*",
    "worker-configuration.d.ts"
  ]
}
